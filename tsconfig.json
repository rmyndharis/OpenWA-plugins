{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true
  },
  "include": ["*/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", ".worktrees", "*/dist"]
}
