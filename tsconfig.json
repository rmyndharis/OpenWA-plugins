{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true
  },
  "include": [
    "gsheets-logger/**/*.ts",
    "faq-bot/**/*.ts",
    "after-hours/**/*.ts",
    "chat-flow/**/*.ts",
    "group-translate/**/*.ts",
    "voice-transcription/**/*.ts",
    "chatwoot-adapter/**/*.ts",
    "typebot-connector/**/*.ts",
    "http-action/**/*.ts",
    "types/**/*.d.ts"
  ]
}
