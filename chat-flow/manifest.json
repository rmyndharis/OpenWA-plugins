{
  "id": "chat-flow",
  "name": "Chat Flow",
  "version": "1.0.7",
  "type": "extension",
  "main": "dist/index.js",
  "description": "Interactive, stateful auto-reply: a trigger word starts a greeting + numbered menu, replies traverse a configurable menu tree, and per-chat state expires after 15 minutes.",
  "author": "Yudhi Armyndharis <yudhi@rmyndharis.com>",
  "license": "MIT",
  "homepage": "https://github.com/rmyndharis/OpenWA-plugins/tree/main/chat-flow",
  "repository": "https://github.com/rmyndharis/OpenWA-plugins",
  "keywords": [
    "menu",
    "flow",
    "interactive",
    "auto-reply",
    "chatbot",
    "whatsapp",
    "openwa"
  ],
  "status": "stable",
  "minOpenWAVersion": "0.7.0",
  "testedOpenWAVersion": "0.8.1",
  "provides": [
    "auto-reply"
  ],
  "permissions": [
    "messages:send"
  ],
  "sessionScoped": true,
  "sessions": [
    "*"
  ],
  "hooks": [
    "message:received"
  ],
  "configUi": {
    "entry": "config/index.html",
    "height": 600
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "trigger": {
        "type": "string",
        "title": "Trigger word",
        "description": "The word that starts the flow (case-insensitive). Leave empty to start on any message."
      },
      "greeting": {
        "type": "textarea",
        "required": true,
        "title": "Greeting + menu",
        "description": "Sent when the flow starts. Include your numbered menu here."
      },
      "respondInGroups": {
        "type": "boolean",
        "default": false,
        "title": "Also respond in group chats"
      },
      "options": {
        "type": "array",
        "title": "Menu options",
        "description": "The menu tree. Each option has a key (what the user types, e.g. \"1\"), the reply text, and optional sub-options. Edit visually in the Flow editor.",
        "items": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string",
              "title": "Key"
            },
            "text": {
              "type": "textarea",
              "title": "Reply text"
            },
            "options": {
              "type": "array",
              "title": "Sub-options",
              "items": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string",
                    "title": "Key"
                  },
                  "text": {
                    "type": "textarea",
                    "title": "Reply text"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "i18n": {
    "es": {
      "name": "Flujo de Chat",
      "description": "Auto-respuesta interactiva con estado: una palabra clave abre un saludo y un menú numerado; las respuestas recorren un árbol de menús configurable.",
      "config": {
        "trigger": {
          "title": "Palabra clave"
        },
        "greeting": {
          "title": "Saludo + menú"
        },
        "respondInGroups": {
          "title": "Responder también en grupos"
        },
        "options": {
          "title": "Opciones del menú"
        }
      }
    },
    "fr": {
      "name": "Flux de Chat",
      "description": "Réponse automatique interactive et avec état : un mot-clé ouvre un message d'accueil et un menu numéroté ; les réponses parcourent une arborescence de menus configurable.",
      "config": {
        "trigger": {
          "title": "Mot-clé déclencheur"
        },
        "greeting": {
          "title": "Message d'accueil + menu"
        },
        "respondInGroups": {
          "title": "Répondre aussi dans les groupes"
        },
        "options": {
          "title": "Options du menu"
        }
      }
    },
    "it": {
      "name": "Flusso di Chat",
      "description": "Risposta automatica interattiva e con stato: una parola chiave apre un saluto e un menu numerato; le risposte percorrono un albero di menu configurabile.",
      "config": {
