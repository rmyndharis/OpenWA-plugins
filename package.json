{
  "name": "openwa-plugins",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Official & community plugins for OpenWA.",
  "license": "MIT",
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "for d in */; do if [ -f \"${d}manifest.json\" ]; then node package.mjs \"${d%/}\"; fi; done",
    "catalog": "node scripts/catalog.mjs",
    "catalog:check": "node scripts/catalog.mjs --check",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --experimental-test-coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
